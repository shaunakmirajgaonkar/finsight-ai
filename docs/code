# TAB 1 — CHAT
# ═════════════════════════════════════════════════════════════
with tab_chat:
    if not st.session_state.selected_docs:
        st.markdown("""
        <div class="empty-state">
            <div class="icon">📂</div>
            <h3>No documents selected</h3>
            <p>Select one or more documents from the sidebar to start your analysis.</p>
        </div>
        """, unsafe_allow_html=True)
    else:
        # Context banner
        tags = ""
        for doc in st.session_state.documents:
            if doc["id"] in st.session_state.selected_docs:
                tags += f'<span class="doc-tag">{doc["company"]} {doc["year"]}</span>'
        st.markdown(f"""
        <div class="context-banner">
            <span>📎 Analysing</span>
            <div class="doc-tags">{tags}</div>
        </div>
        """, unsafe_allow_html=True)

        # Suggestion chips
        cols = st.columns(3)
        for idx, q in enumerate(SUGGESTIONS):
            with cols[idx % 3]:
                if st.button(q, key=f"chip_{idx}", use_container_width=True):
                    st.session_state.chip_text = q

        st.markdown('<div style="height:8px;"></div>', unsafe_allow_html=True)

        # Input form
        col_form, col_rec = st.columns([5, 1])
        with col_rec:
            include_rec = st.checkbox("Signal", value=True,
                                      help="Include BUY/HOLD/SELL signal")

        with st.form("chat_form", clear_on_submit=True):
            col_inp, col_btn = st.columns([6, 1])
            with col_inp:
                user_input = st.text_input(
                    "q", value=st.session_state.chip_text,
                    placeholder="Ask anything about this document…",
                    label_visibility="collapsed",
                )
            with col_btn:
                submitted = st.form_submit_button(
                    "Send", use_container_width=True, type="primary")

        if st.session_state.chip_text and not submitted:
            st.session_state.chip_text = ""

        # API call — fires ONCE per form submit
        if submitted:
            q = user_input.strip()
            if q:
                st.session_state.history.append({"role": "user", "content": q})
                with st.spinner("Retrieving context · Generating response…"):
                    res = api_post("/api/chat", json_data={
                        "question": q,
                        "doc_ids":  st.session_state.selected_docs,
                        "include_recommendation": include_rec,
                    })
                if res:
                    st.session_state.history.append({
                        "role":           "assistant",
                        "content":        res.get("answer", ""),
                        "sources":        res.get("sources", []),
                        "recommendation": res.get("recommendation"),
                    })
                else:
                    st.session_state.history.append({
                        "role":    "assistant",
                        "content": "Unable to get a response. Check the backend is running.",
                        "sources": [],
                    })

        # Chat history
        if not st.session_state.history:
            st.markdown("""
            <div style="text-align:center;padding:40px 0;color:#94A3B8;font-size:13px;">
                Your conversation will appear here.
            </div>
            """, unsafe_allow_html=True)

        for msg in st.session_state.history:
            if msg["role"] == "user":
                st.markdown(
                    f'<div class="msg-row-user">'
                    f'<div class="bubble-user">{msg["content"]}</div></div>',
                    unsafe_allow_html=True)
            else:
                st.markdown(
                    f'<div class="msg-row-ai">'
                    f'<div class="ai-avatar">AI</div>'
                    f'<div class="bubble-ai">{msg["content"]}</div></div>',
                    unsafe_allow_html=True)
                srcs = msg.get("sources", [])
                if srcs:
                    with st.expander(f"  {len(srcs)} source excerpt(s)", expanded=False):
                        for n, src in enumerate(srcs, 1):
                            name = next(
                                (f"{d['company']} {d['year']}"
                                 for d in st.session_state.documents
                                 if d["id"] == src["doc_id"]),
                                src["doc_id"][:8])
                            st.markdown(
                                f'<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">'
                                f'<span style="font-family:JetBrains Mono,monospace;font-size:11px;color:#64748B;">[{n}]</span>'
                                f'<strong style="font-size:13px;">{name}</strong>'
                                f'<span style="font-size:11px;color:#94A3B8;">Page {src["page"]} · {src["relevance_score"]:.0%} match</span></div>',
                                unsafe_allow_html=True)
                            st.caption(src["text"][:300] + ("…" if len(src["text"]) > 300 else ""))
                            if n < len(srcs):
                                st.divider()
                rec = msg.get("recommendation")
                if rec:
                    st.markdown(signal_badge(rec["rating"], rec["confidence"]),
                                unsafe_allow_html=True)
                    if rec.get("rationale"):
                        st.caption(rec["rationale"])

        # ── Export & Clear ────────────────────────────────
        if st.session_state.history:
            st.markdown('<div style="height:12px;"></div>', unsafe_allow_html=True)
            st.markdown("""
            <div style="background:white;border:1px solid #E2E8F0;border-radius:8px;
                        padding:14px 18px;margin-bottom:8px;">
                <div style="font-size:13px;color:#475569;margin-bottom:10px;font-weight:500;">
                    📄 Export conversation as PDF report
                </div>
            """, unsafe_allow_html=True)

            exp_col1, exp_col2 = st.columns([3, 1])
            with exp_col1:
                st.caption("Includes all Q&A, source citations, and investment signals")
            with exp_col2:
                generate = st.button("Generate PDF",
                                     type="primary", use_container_width=True)

            if generate:
                with st.spinner("Building PDF report…"):
                    pdf_bytes = generate_chat_pdf(
                        history=st.session_state.history,
                        documents=st.session_state.documents,
                        selected_doc_ids=st.session_state.selected_docs,
                    )
                st.download_button(
                    label="⬇️  Download PDF Report",
                    data=pdf_bytes,
                    file_name=f"finsight_{datetime.now().strftime('%Y%m%d_%H%M')}.pdf",
                    mime="application/pdf",
                    use_container_width=True,
                )

            st.markdown('</div>', unsafe_allow_html=True)

            if st.button("Clear conversation", type="secondary"):
                st.session_state.history = []
                st.session_state.chip_text = ""
                st.rerun()


