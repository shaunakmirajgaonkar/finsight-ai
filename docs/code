            <div class="icon">📝</div>
            <h3>No documents selected</h3>
            <p>Select a document from the sidebar to generate an executive summary.</p>
        </div>
        """, unsafe_allow_html=True)
    else:
        doc_opts = {
            d["id"]: f"{d['company']} {d['year']} — {d['filename']}"
            for d in st.session_state.documents
            if d["id"] in st.session_state.selected_docs
        }
        chosen = st.selectbox("Document", list(doc_opts.keys()),
                               format_func=lambda x: doc_opts[x],
                               label_visibility="collapsed")

        meta = next((d for d in st.session_state.documents if d["id"] == chosen), None)
        if meta:
            c1, c2, c3, c4 = st.columns(4)
            lbl = meta.get("sentiment_label","neutral")
            scr = meta.get("sentiment_score") or 0
            for col, label, val, delta, dcls in [
                (c1, "COMPANY", meta["company"], "", ""),
                (c2, "YEAR", str(meta["year"]), "", ""),
                (c3, "PAGES", str(meta.get("page_count","—")), "", ""),
                (c4, "SENTIMENT", lbl.upper(), f"{scr:+.3f}",
                 "delta-up" if scr > 0 else "delta-dn"),
            ]:
                col.markdown(f"""
                <div class="metric-card">
                    <div class="label">{label}</div>
                    <div class="value">{val}</div>
                    {f'<div class="delta {dcls}">{delta}</div>' if delta else ''}
                </div>
                """, unsafe_allow_html=True)
            st.markdown('<div style="height:16px;"></div>', unsafe_allow_html=True)

        if st.button("Generate Executive Summary", type="primary", use_container_width=True):
            with st.spinner("Reading document · Generating summary…"):
                res = api_post("/api/summary", json_data={"doc_id": chosen})
            if res:
                st.markdown("---")
                lbl = res.get("sentiment_label", "neutral")
                st.markdown(
                    f'<div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">'
                    f'<h3 style="margin:0;font-size:17px;color:#0B1120;">'
                    f'{res["company"]} · FY{res["year"]}</h3>'
                    f'{sentiment_pill(lbl)}</div>',
                    unsafe_allow_html=True)
                st.markdown(f"""
                <div style="background:white;border:1px solid #E2E8F0;border-radius:8px;
                            padding:24px;line-height:1.7;font-size:14px;color:#1E293B;">
                {res["summary"].replace(chr(10), "<br>")}
                </div>
                """, unsafe_allow_html=True)


