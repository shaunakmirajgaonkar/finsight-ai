def generate_chat_pdf(history, documents, selected_doc_ids):
    buf   = io.BytesIO()
    W, H  = A4
    MRG   = 20 * mm
    NAVY  = colors.HexColor("#0B1120")
    BLUE  = colors.HexColor("#2563EB")
    LBLUE = colors.HexColor("#EFF6FF")
    SLATE = colors.HexColor("#64748B")
    LGREY = colors.HexColor("#F8FAFC")
    BORD  = colors.HexColor("#E2E8F0")
    GREEN = colors.HexColor("#10B981")
    AMBER = colors.HexColor("#F59E0B")
    RED   = colors.HexColor("#EF4444")
    WHITE = colors.white
    BLACK = colors.HexColor("#1E293B")

    doc = SimpleDocTemplate(buf, pagesize=A4,
        leftMargin=MRG, rightMargin=MRG,
        topMargin=MRG, bottomMargin=20*mm,
        title="FinSight AI Report", author="FinSight AI")

    story = []
    now   = datetime.now().strftime("%B %d, %Y  %H:%M")

    # ── Header ──
    hdr = Table([[
        Paragraph("FINSIGHT//AI", ParagraphStyle("logo",
            fontName="Helvetica-Bold", fontSize=14,
            textColor=BLUE, charSpace=2)),
        Paragraph(f"Generated: {now}", ParagraphStyle("ts",
            fontName="Helvetica", fontSize=9,
            textColor=SLATE, alignment=TA_RIGHT)),
    ]], colWidths=[W-2*MRG-60*mm, 60*mm])
    hdr.setStyle(TableStyle([
        ("VALIGN",(0,0),(-1,-1),"MIDDLE"),
        ("LINEBELOW",(0,0),(-1,-1),0.5,BORD),
        ("BOTTOMPADDING",(0,0),(-1,-1),10),
    ]))
    story.append(hdr)
    story.append(Spacer(1, 6*mm))

    story.append(Paragraph("Financial Analysis Report",
        ParagraphStyle("title", fontName="Helvetica-Bold",
            fontSize=20, textColor=NAVY, leading=26, spaceAfter=4)))
    story.append(Paragraph(
        "AI-generated insights from financial document analysis",
        ParagraphStyle("sub", fontName="Helvetica",
            fontSize=10, textColor=SLATE, leading=14)))
    story.append(Spacer(1, 5*mm))

    # ── Documents table ──
    active = [d for d in documents if d["id"] in selected_doc_ids]
    if active:
        rows = [["Company","Year","Type","Pages","Sentiment"]]
        for d in active:
            rows.append([
                d.get("company","—"), str(d.get("year","—")),
                d.get("doc_type","—").replace("_"," ").title(),
                str(d.get("page_count","—")),
                d.get("sentiment_label","—").capitalize(),
            ])
        dt = Table(rows, colWidths=[55*mm,18*mm,42*mm,18*mm,30*mm])
        dt.setStyle(TableStyle([
            ("BACKGROUND",(0,0),(-1,0),NAVY),
            ("TEXTCOLOR",(0,0),(-1,0),WHITE),
            ("FONTNAME",(0,0),(-1,0),"Helvetica-Bold"),
            ("FONTSIZE",(0,0),(-1,0),8),
            ("FONTNAME",(0,1),(-1,-1),"Helvetica"),
            ("FONTSIZE",(0,1),(-1,-1),9),
            ("TEXTCOLOR",(0,1),(-1,-1),BLACK),
            ("GRID",(0,0),(-1,-1),0.4,BORD),
            ("ROWBACKGROUNDS",(0,1),(-1,-1),[WHITE,LGREY]),
            ("TOPPADDING",(0,0),(-1,-1),5),
            ("BOTTOMPADDING",(0,0),(-1,-1),5),
            ("LEFTPADDING",(0,0),(-1,-1),8),
            ("VALIGN",(0,0),(-1,-1),"MIDDLE"),
        ]))
        story.append(dt)
        story.append(Spacer(1, 4*mm))

    # ── Stats bar ──
    pairs_all = []
    i = 0
    while i < len(history):
        if (history[i]["role"] == "user" and
                i+1 < len(history) and
                history[i+1]["role"] == "assistant"):
            pairs_all.append((history[i]["content"], history[i+1]))
            i += 2
        else:
            i += 1

    n_sig = sum(1 for _, a in pairs_all if a.get("recommendation"))
    stats = Table([[
        Paragraph(f"<b>{len(pairs_all)}</b>  Questions",
            ParagraphStyle("st", fontName="Helvetica", fontSize=10, textColor=NAVY)),
        Paragraph(f"<b>{n_sig}</b>  Signals Generated",
            ParagraphStyle("st2", fontName="Helvetica", fontSize=10, textColor=NAVY)),
        Paragraph(f"<b>{len(active)}</b>  Documents",
            ParagraphStyle("st3", fontName="Helvetica", fontSize=10, textColor=NAVY)),
    ]], colWidths=[(W-2*MRG)/3]*3)
    stats.setStyle(TableStyle([
        ("BACKGROUND",(0,0),(-1,-1),LBLUE),
        ("LINEBELOW",(0,0),(-1,-1),2,BLUE),
        ("TOPPADDING",(0,0),(-1,-1),8),
        ("BOTTOMPADDING",(0,0),(-1,-1),8),
        ("LEFTPADDING",(0,0),(-1,-1),12),
        ("VALIGN",(0,0),(-1,-1),"MIDDLE"),
        ("ALIGN",(0,0),(-1,-1),"CENTER"),
    ]))
    story.append(stats)
    story.append(Spacer(1, 8*mm))

    # ── Q&A ──
    story.append(Paragraph("ANALYSIS & RESPONSES",
        ParagraphStyle("sl", fontName="Helvetica-Bold",
            fontSize=7, textColor=SLATE, charSpace=1.5, spaceAfter=4)))
    story.append(HRFlowable(width="100%", thickness=0.5,
                             color=BORD, spaceAfter=4*mm))

    for idx, (question, amsg) in enumerate(pairs_all, 1):
        block = []

        # Question bubble
        qt = Table([[
            Paragraph(f"Q{idx}", ParagraphStyle("qn",
                fontName="Helvetica-Bold", fontSize=8,
                textColor=BLUE, leading=11)),
            Paragraph(question, ParagraphStyle("q",
                fontName="Helvetica-Bold", fontSize=11,
                textColor=WHITE, leading=16)),
        ]], colWidths=[10*mm, W-2*MRG-10*mm])
        qt.setStyle(TableStyle([
            ("BACKGROUND",(0,0),(-1,-1),NAVY),
            ("TOPPADDING",(0,0),(-1,-1),10),
            ("BOTTOMPADDING",(0,0),(-1,-1),10),
            ("LEFTPADDING",(0,0),(0,-1),10),
            ("LEFTPADDING",(1,0),(1,-1),6),
            ("RIGHTPADDING",(0,0),(-1,-1),12),
            ("VALIGN",(0,0),(-1,-1),"TOP"),
        ]))
        block.append(qt)
        block.append(Spacer(1, 2*mm))

        # Answer bubble
        content = (amsg.get("content","")
            .replace("&","&amp;")
            .replace("<","&lt;")
            .replace(">","&gt;")
            .replace("\n","<br/>"))
        at = Table([[Paragraph(content,
            ParagraphStyle("a", fontName="Helvetica",
                fontSize=10, textColor=BLACK, leading=15))]],
            colWidths=[W-2*MRG])
        at.setStyle(TableStyle([
            ("BACKGROUND",(0,0),(-1,-1),WHITE),
            ("BOX",(0,0),(-1,-1),0.5,BORD),
            ("TOPPADDING",(0,0),(-1,-1),10),
            ("BOTTOMPADDING",(0,0),(-1,-1),10),
            ("LEFTPADDING",(0,0),(-1,-1),12),
            ("RIGHTPADDING",(0,0),(-1,-1),12),
        ]))
        block.append(at)

        # Sources
        srcs = amsg.get("sources", [])
        if srcs:
            block.append(Spacer(1, 2*mm))
            src_rows = [["#","Document","Page","Match","Excerpt"]]
            for n, src in enumerate(srcs[:4], 1):
                dname = next(
                    (f"{d['company']} {d['year']}"
                     for d in documents if d["id"] == src["doc_id"]),
                    src["doc_id"][:10])
                exc = src["text"][:100].replace("\n"," ")
                if len(src["text"]) > 100:
                    exc += "…"
                src_rows.append([str(n), dname, str(src["page"]),
                    f"{src['relevance_score']:.0%}", exc])
            st_src = Table(src_rows,
                colWidths=[8*mm,35*mm,12*mm,14*mm,W-2*MRG-69*mm])
            st_src.setStyle(TableStyle([
                ("BACKGROUND",(0,0),(-1,0),LBLUE),
                ("TEXTCOLOR",(0,0),(-1,0),BLUE),
                ("FONTNAME",(0,0),(-1,0),"Helvetica-Bold"),
                ("FONTSIZE",(0,0),(-1,0),7),
                ("FONTNAME",(0,1),(-1,-1),"Helvetica"),
                ("FONTSIZE",(0,1),(-1,-1),8),
                ("TEXTCOLOR",(0,1),(-1,-1),SLATE),
                ("GRID",(0,0),(-1,-1),0.3,BORD),
                ("TOPPADDING",(0,0),(-1,-1),4),
                ("BOTTOMPADDING",(0,0),(-1,-1),4),
                ("LEFTPADDING",(0,0),(-1,-1),6),
                ("VALIGN",(0,0),(-1,-1),"TOP"),
            ]))
            block.append(st_src)

        # Signal
        rec = amsg.get("recommendation")
        if rec:
            block.append(Spacer(1, 2*mm))
            rating = rec.get("rating","HOLD")
            conf   = rec.get("confidence", 0.5)
            sc = {"BUY":GREEN,"HOLD":AMBER,"SELL":RED}.get(rating, SLATE)
            sb = {"BUY":  colors.HexColor("#ECFDF5"),
                  "HOLD": colors.HexColor("#FFFBEB"),
                  "SELL": colors.HexColor("#FEF2F2")}.get(rating, LGREY)
            sig = Table([[
                Paragraph(f"<b>{rating}</b>  ·  {int(conf*100)}% confidence",
                    ParagraphStyle("sig", fontName="Helvetica-Bold",
                        fontSize=11, textColor=sc)),
                Paragraph(rec.get("rationale",""),
                    ParagraphStyle("rat", fontName="Helvetica-Oblique",
                        fontSize=9, textColor=SLATE, leading=13)),
            ]], colWidths=[50*mm, W-2*MRG-50*mm])
            sig.setStyle(TableStyle([
                ("BACKGROUND",(0,0),(-1,-1),sb),
                ("LINEBELOW",(0,0),(-1,-1),2,sc),
                ("TOPPADDING",(0,0),(-1,-1),8),
                ("BOTTOMPADDING",(0,0),(-1,-1),8),
                ("LEFTPADDING",(0,0),(-1,-1),10),
                ("VALIGN",(0,0),(-1,-1),"MIDDLE"),
            ]))
            block.append(sig)

        block.append(Spacer(1, 6*mm))
        story.append(KeepTogether(block))

    # ── Footer ──
    story.append(HRFlowable(width="100%", thickness=0.5,
                             color=BORD, spaceBefore=4*mm, spaceAfter=3*mm))
    story.append(Paragraph(
        f"Generated by FinSight AI · {now} · "
        "For informational purposes only. Not financial advice.",
        ParagraphStyle("ft", fontName="Helvetica", fontSize=8,
                        textColor=SLATE, alignment=TA_CENTER)))

    doc.build(story)
    buf.seek(0)
    return buf.read()


