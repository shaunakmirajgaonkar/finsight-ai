def api_get(path):
    try:
        r = requests.get(f"{API_BASE}{path}", timeout=10)
        r.raise_for_status()
        return r.json()
    except requests.ConnectionError:
        st.error("Backend offline — run: `uvicorn app.main:app --reload --port 8000`")
    except Exception as e:
        st.error(f"Error: {e}")
    return None

def api_post(path, json_data=None, files=None, data=None, timeout=120):
    try:
        r = requests.post(f"{API_BASE}{path}", json=json_data,
                          files=files, data=data, timeout=timeout)
        r.raise_for_status()
        return r.json()
    except requests.ConnectionError:
        st.error("Backend offline.")
    except requests.HTTPError as e:
        try:
            detail = e.response.json().get("detail", str(e))
        except Exception:
            detail = str(e)
        st.error(f"API error: {detail}")
    except Exception as e:
        st.error(f"Request failed: {e}")
    return None

def api_delete(path):
    try:
        requests.delete(f"{API_BASE}{path}", timeout=10).raise_for_status()
        return True
    except Exception:
        return False

def refresh_docs():
    docs = api_get("/api/documents/")
    if docs is not None:
        st.session_state.documents = docs

def sentiment_pill(label):
    color, bg, text = SENTIMENT_COLOR.get(
        label, ("#94A3B8", "#1e293b", label.upper()))
    return (f'<span class="sentiment-pill" '
            f'style="background:{bg};color:{color};border:1px solid {color}22;">'
            f'{text}</span>')

def signal_badge(rating, confidence):
    color, bg = RATING_COLOR.get(rating, ("#94A3B8", "#1e293b"))
    return (f'<div class="signal-badge" style="background:{bg};border:1px solid {color}33;">'
            f'<span class="rating" style="color:{color};">{rating}</span>'
            f'<span class="conf" style="color:{color};">'
            f'{int(confidence * 100)}% confidence</span></div>')

def doc_type_badge(doc_type):
    return DOC_TYPE_ICONS.get(doc_type, "DOC")


